# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files (can opt-in for committing if needed)
.env*
VERCEL_ENV.txt

# Stripe CLI and ngrok
stripe-cli/
ngrok/
*.zip

# backfill output (contains customer PII)
scripts/backfill-list.json

# debug/secret dumps — never commit
debug-apikey.json
debug-error.json
firestore-debug.log
firebase-debug.log

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts

.vercel
